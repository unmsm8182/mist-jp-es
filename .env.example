# MIST-JP/ES Environment Configuration
# Copia este archivo como .env y ajusta los valores

# HuggingFace (opcional, para modelos privados o evitar rate limits)
# HF_TOKEN=hf_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Rutas de modelos (opcional, para usar modelos locales)
# TRANSLATION_MODEL_PATH=Helsinki-NLP/opus-mt-ja-es
# INTENT_MODEL_PATH=cl-tohoku/bert-base-japanese
# TONE_MODEL_PATH=cl-tohoku/bert-base-japanese

# Cache de modelos HuggingFace
# TRANSFORMERS_CACHE=./models_cache

# Logging
LOG_LEVEL=INFO

# Entorno
ENV=development
